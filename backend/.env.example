# Copy this file to `.env` and fill in real values. NEVER commit the real .env.
#
#   cd backend && cp .env.example .env

# ── Required ──────────────────────────────────────────────────────────────────
# Long random string used to sign login tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# ── Optional: port (host usually sets this) ──────────────────────────────────
# PORT=3000

# ── Optional: AI features (label scanner, food pairings, translation) ────────
# Get a key at https://console.anthropic.com
# ANTHROPIC_API_KEY=

# ── Optional: password-reset emails (any SMTP provider, e.g. Resend) ─────────
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASS=
# EMAIL_FROM="Sipiary <no-reply@yourdomain.com>"
# APP_URL=https://sipiary.fly.dev      # base for links in reset emails

# ── Optional: off-site DB backups (Litestream → Cloudflare R2) ───────────────
# R2_BUCKET=
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# LITESTREAM_ACCESS_KEY_ID=
# LITESTREAM_SECRET_ACCESS_KEY=

# ── Optional: CORS (only if frontend is served from a different origin) ──────
# ALLOWED_ORIGIN=https://yourdomain.com
